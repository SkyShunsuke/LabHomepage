# Local PostgreSQL example:
# postgresql://postgres:postgres@localhost:5432/lab_homepage?schema=public
# Railway will provide this automatically.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lab_homepage?schema=public"

# Change these in production.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me"
ADMIN_SECRET="replace-with-a-long-random-secret"

# Public contact values
NEXT_PUBLIC_LAB_EMAIL="t-hase@u-fukui.ac.jp"
NEXT_PUBLIC_LAB_ADDRESS="3-9-1 Bunkyo, Fukui, 910-0017"

# Optional: remote publications CSV (Google Drive / Google Sheets / direct CSV URL).
# If set, /publications uses this CSV instead of DB data.
# For Google Drive file URLs, share as "Anyone with the link can view".
PUBLICATIONS_CSV_URL=""
# How often Next.js refetches the remote CSV, in seconds.
PUBLICATIONS_CSV_REVALIDATE_SECONDS="300"

# Optional: remote members spreadsheet (Google Drive / Google Sheets / direct CSV URL).
# If set, /members uses this spreadsheet instead of DB member data.
# Required headers: name, role
# Optional headers: email, homepage, researchArea, comment, imageUrl
MEMBERS_SPREADSHEET_URL=""
# How often Next.js refetches the remote spreadsheet, in seconds.
MEMBERS_SPREADSHEET_REVALIDATE_SECONDS="300"

# Optional: remote news spreadsheet (Google Drive / Google Sheets / direct CSV URL).
# If locale-specific URLs are set, /news and homepage latest news use
# NEWS_JA_SPREADSHEET_URL for Japanese and NEWS_EN_SPREADSHEET_URL for English.
# NEWS_SPREADSHEET_URL works as a fallback for both locales.
# Required headers: date, title, content
# Optional headers: type, highlight, imageUrl, externalUrl
NEWS_JA_SPREADSHEET_URL=""
NEWS_EN_SPREADSHEET_URL=""
NEWS_SPREADSHEET_URL=""
# How often Next.js refetches the remote spreadsheet, in seconds.
NEWS_SPREADSHEET_REVALIDATE_SECONDS="300"
